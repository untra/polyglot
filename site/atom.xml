---
layout: null
permalink: /atom.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ site.active_lang }}">
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator>
  <link href="{{ site.url }}{% if site.active_lang != site.default_lang %}/{{ site.active_lang }}{% endif %}/atom.xml" rel="self" type="application/atom+xml"/>
  <link href="{{ site.url }}{% if site.active_lang != site.default_lang %}/{{ site.active_lang }}{% endif %}/" rel="alternate" type="text/html" hreflang="{{ site.active_lang }}"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ site.url }}{% if site.active_lang != site.default_lang %}/{{ site.active_lang }}{% endif %}/atom.xml</id>
  <title type="html">{{ site.title | smartify | xml_escape }}</title>
  <subtitle>{{ site.description[site.active_lang] | default: site.tagline | xml_escape }}</subtitle>
  {% if site.author.name %}
  <author>
    <name>{{ site.author.name | xml_escape }}</name>
    {% if site.author.url %}<uri>{{ site.author.url | xml_escape }}</uri>{% endif %}
  </author>
  {% endif %}
  {% for post in site.posts limit: 10 %}
  <entry>
    <title type="html">{{ post.title | smartify | strip_html | normalize_whitespace | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" title="{{ post.title | xml_escape }}"/>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</updated>
    <id>{{ post.id | absolute_url | xml_escape }}</id>
    <content type="html" xml:base="{{ post.url | absolute_url | xml_escape }}">{{ post.content | strip | xml_escape }}</content>
    <summary type="html">{{ post.excerpt | strip_html | normalize_whitespace | xml_escape }}</summary>
  </entry>
  {% endfor %}
</feed>
